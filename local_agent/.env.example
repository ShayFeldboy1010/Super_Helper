# Supabase connection (same as the bot's)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Path to the AI_Super_man project root
PROJECT_DIR=/Users/shayFeldboy/Documents/shay/AI_Super_man

# Polling interval in seconds
POLL_INTERVAL=30

# Claude Code CLI command (default: claude)
CLAUDE_CMD=claude

# Claude Code execution timeout in seconds
CLAUDE_TIMEOUT=300

# Auto-commit and push after successful execution
AUTO_COMMIT=true
AUTO_PUSH=true

# Telegram — for instant notifications when tasks complete
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-user-id
